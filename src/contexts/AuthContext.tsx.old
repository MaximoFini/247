import React, {
  createContext,
  useContext,
  useEffect,
  useState,
  useRef,
  useCallback,
} from "react";
import { User, Session } from "@supabase/supabase-js";
import { supabase } from "@/lib/supabase/client";
import type { User as DBUser } from "@/types/database";

interface AuthContextType {
  user: User | null;
  dbUser: DBUser | null;
  session: Session | null;
  loading: boolean;
  signInWithGoogle: () => Promise<void>;
  signOut: () => Promise<void>;
  isAdmin: boolean;
}

const AuthContext = createContext<AuthContextType | undefined>(undefined);

// Claves de storage
const DBUSER_STORAGE_KEY = "dbUser";
const AUTH_STORAGE_KEYS = ["dbUser", "sb-nesbqbdqeieyjuvkhwhf-auth-token"];

// ⚡ OPTIMIZACIÓN FASE 1: Timeouts reducidos
const AUTH_TIMEOUT_MS = 3000; // Reducido de 8s a 3s
const DBUSER_FETCH_TIMEOUT_MS = 4000; // 4s para fetch de dbUser
const LOADING_SAFETY_TIMEOUT_MS = 5000; // 5s máximo de loading (reducido de 10s)

// Helper para limpiar todo el storage relacionado con auth
function clearAllAuthStorage() {
  try {
    AUTH_STORAGE_KEYS.forEach((key) => {
      sessionStorage.removeItem(key);
      localStorage.removeItem(key);
    });
    // Limpiar cualquier cosa de supabase en localStorage
    Object.keys(localStorage).forEach((key) => {
      if (key.startsWith("sb-")) {
        localStorage.removeItem(key);
      }
    });
  } catch (e) {
    console.warn("⚠️ Error limpiando storage:", e);
  }
}

// Helper para crear promesa con timeout
function withTimeout<T>(
  promise: Promise<T>,
  ms: number,
  errorMsg: string,
): Promise<T> {
  return Promise.race([
    promise,
    new Promise<T>((_, reject) =>
      setTimeout(() => reject(new Error(errorMsg)), ms),
    ),
  ]);
}

export function AuthProvider({ children }: { children: React.ReactNode }) {
  const [user, setUser] = useState<User | null>(null);
  const [dbUser, setDbUser] = useState<DBUser | null>(() => {
    try {
      const cached = sessionStorage.getItem(DBUSER_STORAGE_KEY);
      return cached ? JSON.parse(cached) : null;
    } catch {
      return null;
    }
  });
  const [session, setSession] = useState<Session | null>(null);
  const [loading, setLoading] = useState(true);

  const dbUserRef = useRef<DBUser | null>(dbUser);
  const fetchingRef = useRef<boolean>(false);
  const initializedRef = useRef<boolean>(false);
  const loadingTimeoutRef = useRef<NodeJS.Timeout | null>(null);
  
  // ⚡ OPTIMIZACIÓN FASE 1: Track si ya se procesó la sesión inicial
  const initialSessionProcessedRef = useRef<boolean>(false);

  // ⚠️ FALLBACK DE SEGURIDAD: Forzar loading=false después de 5s máximo
  useEffect(() => {
    if (loading) {
      loadingTimeoutRef.current = setTimeout(() => {
        console.warn("⚠️ Loading timeout (5s) - forzando loading=false");
        setLoading(false);
      }, LOADING_SAFETY_TIMEOUT_MS); // ⚡ Reducido de 10s a 5s
    } else {
      if (loadingTimeoutRef.current) {
        clearTimeout(loadingTimeoutRef.current);
        loadingTimeoutRef.current = null;
      }
    }

    return () => {
      if (loadingTimeoutRef.current) {
        clearTimeout(loadingTimeoutRef.current);
      }
    };
  }, [loading]);

  useEffect(() => {
    dbUserRef.current = dbUser;
  }, [dbUser]);

  useEffect(() => {
    try {
      if (dbUser) {
        sessionStorage.setItem(DBUSER_STORAGE_KEY, JSON.stringify(dbUser));
      } else {
        sessionStorage.removeItem(DBUSER_STORAGE_KEY);
      }
    } catch (error) {
      console.warn("⚠️ Error guardando en sessionStorage:", error);
    }
  }, [dbUser]);

  const fetchDbUser = useCallback(
    async (userId: string, forceRefresh = false) => {
      // Evitar llamadas duplicadas
      if (fetchingRef.current) {
        console.log("⏭️ fetchDbUser ya en progreso, saltando...");
        return;
      }

      const currentDbUser = dbUserRef.current;
      
      // Si ya tenemos el usuario y no es force refresh, usar caché
      if (!forceRefresh && currentDbUser && currentDbUser.id === userId) {
        console.log("✅ dbUser cacheado:", currentDbUser.email);
        setLoading(false);
        return;
      }

      fetchingRef.current = true;
      console.log("🔍 Fetching dbUser:", userId);

      try {
        const { data, error } = await withTimeout(
          supabase
            .from("users")
            .select("id, email, nombre, puntos_archivos, puntos_donaciones, is_admin")
            .eq("id", userId)
            .single(),
          DBUSER_FETCH_TIMEOUT_MS,
          "Timeout fetching dbUser"
        );

        if (error) {
          console.warn("⚠️ Error fetchDbUser:", error.message);
          // Si hay error pero teníamos caché, mantenerlo
          if (!currentDbUser) {
            setDbUser(null);
          }
        } else if (data) {
          console.log("✅ dbUser obtenido:", data.email, "admin:", data.is_admin);
          setDbUser(data);
        }
      } catch (error: any) {
        console.warn("⚠️ Error/timeout en fetchDbUser:", error?.message);
        // Mantener caché si existe
      } finally {
        fetchingRef.current = false;
        setLoading(false);
      }
    },
    [],
  );

  // Efecto principal para manejar autenticación
  useEffect(() => {
    if (initializedRef.current) return;
    initializedRef.current = true;

    console.log(" AuthProvider: Inicializando...");

    // Obtener sesión inicial CON TIMEOUT para evitar que se cuelgue
    const initAuth = async () => {
      try {
        const {
          data: { session: initialSession },
        } = await withTimeout(
          supabase.auth.getSession(),
          AUTH_TIMEOUT_MS,
          "Timeout al obtener sesión",
        );

        console.log(
          " Sesión inicial:",
          initialSession?.user?.email || "No hay sesión",
        );

        // Si hay caché de dbUser pero NO hay sesión válida, limpiar todo (sesión corrupta/expirada)
        if (!initialSession && dbUserRef.current) {
          console.log("⚠️ Sesión expirada detectada, limpiando caché...");
          clearAllAuthStorage();
          setDbUser(null);
          setUser(null);
          setSession(null);
          setLoading(false);
          return;
        }

        setSession(initialSession);
        setUser(initialSession?.user ?? null);

        if (initialSession?.user) {
          fetchDbUser(initialSession.user.id);
        } else {
          setDbUser(null);
          setLoading(false);
        }
      } catch (error) {
        console.error("❌ Error al inicializar auth:", error);

        // ⚠️ CRÍTICO: Solo limpiar si onAuthStateChange NO confirmó una sesión
        // Esto previene race condition donde el timeout borra una sesión válida
        if (!sessionConfirmedRef.current) {
          console.log("🧹 No hay sesión confirmada, limpiando estado...");
          clearAllAuthStorage();
          setDbUser(null);
          setUser(null);
          setSession(null);
          setLoading(false);
        } else {
          console.log(
            "✅ Sesión ya confirmada por listener, ignorando timeout",
          );
          // Solo asegurar que loading sea false
          setLoading(false);
        }
      }
    };

    initAuth();

    // Escuchar cambios de auth
    const {
      data: { subscription },
    } = supabase.auth.onAuthStateChange(async (event, newSession) => {
      console.log(
        "🔄 Auth state cambió:",
        event,
        newSession?.user?.email || "No user",
      );

      setSession(newSession);
      setUser(newSession?.user ?? null);

      // ⚠️ Marcar sesión como confirmada si hay usuario válido
      if (newSession?.user) {
        sessionConfirmedRef.current = true;
      }

      switch (event) {
        case "SIGNED_IN":
          if (newSession?.user) {
            sessionConfirmedRef.current = true;
            await fetchDbUser(newSession.user.id, true);
          }
          break;

        case "SIGNED_OUT":
          sessionConfirmedRef.current = false;
          setDbUser(null);
          setLoading(false);
          clearAllAuthStorage();
          break;

        case "TOKEN_REFRESHED":
          console.log("🔄 Token refrescado - manteniendo estado de dbUser");
          if (!dbUserRef.current && newSession?.user) {
            await fetchDbUser(newSession.user.id);
          } else {
            // Asegurar que loading sea false si ya tenemos dbUser
            setLoading(false);
          }
          break;

        case "USER_UPDATED":
          if (newSession?.user) {
            await fetchDbUser(newSession.user.id, true);
          }
          break;

        case "INITIAL_SESSION":
          // ⚠️ CRÍTICO: Este evento se dispara al recargar página con sesión activa
          // Necesitamos asegurar que el estado se actualice correctamente
          console.log(
            "🔄 INITIAL_SESSION detectada:",
            newSession?.user?.email || "No user",
          );
          if (newSession?.user) {
            // Si hay sesión pero no tenemos dbUser, buscarlo
            if (!dbUserRef.current) {
              await fetchDbUser(newSession.user.id);
            } else {
              // Ya tenemos dbUser cacheado, solo asegurar loading = false
              setLoading(false);
            }
          } else {
            // No hay sesión, asegurar estado limpio
            setDbUser(null);
            setLoading(false);
          }
          break;

        default:
          console.log("� Auth event no manejado:", event);
          if (newSession?.user && !dbUserRef.current) {
            await fetchDbUser(newSession.user.id);
          } else if (newSession?.user && dbUserRef.current) {
            // Ya tenemos todo, asegurar loading = false
            setLoading(false);
          } else if (!newSession) {
            setDbUser(null);
            setLoading(false);
          }
      }
    });

    return () => {
      console.log("🧹 AuthProvider: Cleanup");
      subscription.unsubscribe();
    };
  }, [fetchDbUser]);

  const signInWithGoogle = async () => {
    console.log("🚀 Iniciando login con Google...");
    const { error } = await supabase.auth.signInWithOAuth({
      provider: "google",
      options: {
        redirectTo: `${window.location.origin}`,
        queryParams: {
          access_type: "offline",
          prompt: "consent",
        },
      },
    });

    if (error) {
      console.error("❌ Error en signInWithGoogle:", error);
      throw error;
    }
  };

  const signOut = async () => {
    console.log("👋 Cerrando sesión...");

    // 1. Limpiar estado local PRIMERO
    setDbUser(null);
    setUser(null);
    setSession(null);

    // 2. Limpiar TODO el storage
    clearAllAuthStorage();

    // 3. Resetear el flag de inicialización para permitir re-init limpio
    initializedRef.current = false;
    fetchingRef.current = false;

    // 4. Cerrar sesión en Supab
    sessionConfirmedRef.current = false; // ⚠️ Resetear flag de sesión confirmadaase
    try {
      const { error } = await supabase.auth.signOut({ scope: "local" });
      if (error) {
        console.error("❌ Error en signOut:", error);
      }
    } catch (e) {
      console.error("❌ Error en signOut:", e);
    }

    // 5. Forzar recarga limpia para asegurar estado completamente fresco
    window.location.href = "/";
  };

  // Log del estado actual (útil para debugging)
  useEffect(() => {
    console.log("📊 Estado actual:", {
      loading,
      hasUser: !!user,
      hasDbUser: !!dbUser,
      email: user?.email,
    });
  }, [loading, user, dbUser]);

  return (
    <AuthContext.Provider
      value={{
        user,
        dbUser,
        session,
        loading,
        signInWithGoogle,
        signOut,
        isAdmin: dbUser?.is_admin ?? false,
      }}
    >
      {children}
    </AuthContext.Provider>
  );
}

export function useAuth() {
  const context = useContext(AuthContext);
  if (context === undefined) {
    throw new Error("useAuth must be used within an AuthProvider");
  }
  return context;
}
